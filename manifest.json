{
  "id": "ns-dynamic-island",
  "name": "Dynamic Island",
  "version": "0.6.1",
  "minNoctaliaVersion": "4.6.6",
  "author": "William Theesfeld",
  "license": "MIT",
  "repository": "https://github.com/theesfeld/ns-dynamic-island",
  "description": "A floating, morphing top-of-screen island. Reacts to media, notifications, recording, battery, network, bluetooth, pomodoro, clipboard, screenshots, downloads, CPU/temp, volume/brightness OSD and more.",
  "tags": [
    "Bar",
    "Overlay",
    "Media",
    "Notifications",
    "OSD",
    "Pomodoro",
    "Privacy"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "enabled": true,
      "overlayEnabled": false,
      "overlayInteractive": false,
      "overlayMigrationV052": false,
      "position": "top",
      "marginPx": 6,
      "horizontalOffset": 0,
      "compactWidth": 180,
      "expandedWidth": 440,
      "height": 36,
      "cornerRadius": 18,
      "hideDelaySec": 4,
      "hoverToExpand": true,
      "dualBubble": true,
      "disabledScreens": [],

      "themePreset": "system",
      "highContrast": false,
      "largeText": false,
      "backdropOpacity": 0.94,
      "fakeBlur": true,

      "springExpand": true,
      "criticalGlow": true,
      "timeOfDayTint": true,
      "dynamicMediaAccent": true,
      "smoothMediaPosition": true,
      "iconMicroAnimations": true,

      "swipeGestures": true,
      "scrubMedia": true,
      "contextMenu": true,

      "autoShowOnMedia": true,

      "autoShowOnNotification": true,
      "notificationDurationSec": 5,
      "stackNotifications": true,
      "showNotificationActions": true,
      "dndEnabled": false,
      "dndPausesMediaAutoShow": false,
      "notificationMutedApps": [],
      "notificationPinnedApps": [],

      "detectScreenRecording": true,
      "recordingPollSec": 3,

      "idleShowClock": true,
      "idleShowSeconds": false,
      "idleUse24h": true,
      "idleShowWeather": false,
      "weatherLocation": "",
      "weatherUnits": "metric",
      "weatherCacheEnabled": true,

      "batteryEnabled": true,
      "batteryLowThreshold": 20,
      "batteryPollSec": 30,
      "batteryShowOnChange": true,

      "osdEnabled": true,
      "osdDurationSec": 2,

      "pomodoroEnabled": true,
      "pomodoroWorkMin": 25,
      "pomodoroShortBreakMin": 5,
      "pomodoroLongBreakMin": 15,
      "pomodoroLongBreakEvery": 4,
      "pomodoroAutoDnd": false,

      "timerEnabled": true,

      "privacyIndicatorEnabled": true,
      "privacyPollSec": 4,

      "networkEnabled": true,
      "networkPollSec": 8,

      "bluetoothEnabled": true,

      "keyboardLayoutEnabled": true,

      "workspaceEnabled": true,

      "clipboardEnabled": false,
      "clipboardAutoWatch": false,
      "clipboardPrivacy": true,
      "screenshotEnabled": true,
      "screenshotDir": "",

      "calendarEnabled": false,

      "downloadEnabled": true,

      "cpuEnabled": false,
      "cpuPollSec": 5,
      "cpuTempCritical": 85,

      "barShowClock": true,
      "barShowWeather": true,
      "barShowActiveWindow": true,
      "barShowMedia": true,
      "barShowNotifications": true,
      "barShowRecording": true,
      "barShowBattery": true,
      "barShowPomodoro": true,
      "barShowPrivacy": true,
      "barClickAction": "panel",
      "activeWindowMaxChars": 28,
      "mediaTitleMaxChars": 22,
      "glassEffect": true,
      "barHoverLift": true,
      "barClickRipple": true,
      "barDynamicAccent": true,

      "keyboardLayoutAutoPoll": true,
      "keyboardLayoutPollSec": 2,
      "workspaceAutoPoll": true,
      "workspacePollSec": 2,
      "volumeAutoPoll": true,
      "volumePollMs": 800,
      "brightnessAutoPoll": true,
      "brightnessPollMs": 1200,
      "screenshotAutoWatch": true,
      "screenshotPollSec": 3,

      "notificationSound": false,
      "notificationSoundPath": "",

      "effectsRipple": true,
      "effectsHoverLift": true,
      "effectsTrackFlash": true,
      "effectsAudioBars": true,
      "effectsConfetti": true,
      "effectsNotificationSlide": true,
      "effectsWeatherParticles": true,
      "reducedMotion": false,
      "realBlur": false,
      "realBlurRadius": 18,

      "scrollAdjustsVolume": true,
      "scrollVolumeStep": 5,

      "autoDndOnFullscreen": false,
      "fullscreenPollSec": 4,

      "diskEnabled": false,
      "diskWarnThreshold": 90,
      "diskPollSec": 60,
      "diskMount": "/",

      "netSpeedEnabled": false,
      "netSpeedPollSec": 2,

      "ramEnabled": false,
      "ramWarnThreshold": 85,

      "pomodoroStatsEnabled": true,
      "pomodoroStatsDate": "",
      "pomodoroTodayCycles": 0,
      "pomodoroTodayFocusMin": 0,

      "idleNextEventCountdown": true
    }
  }
}
